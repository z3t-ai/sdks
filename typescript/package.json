      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@google/genai": "^2.10.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
